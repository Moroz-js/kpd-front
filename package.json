{
  "name": "kpd-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/set-prisma-provider.mjs && prisma generate && next dev",
    "build": "node scripts/set-prisma-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/set-prisma-provider.mjs && prisma generate",
    "db:push": "node scripts/set-prisma-provider.mjs && prisma generate && prisma db push",
    "db:migrate": "node scripts/prisma-deploy.mjs",
    "db:migrate:recover": "node scripts/prisma-migrate-recover.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "db:seed": "node scripts/set-prisma-provider.mjs && prisma generate && prisma db seed",
    "db:studio": "node scripts/set-prisma-provider.mjs && prisma generate && prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "prisma": "5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
