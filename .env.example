# Локально — SQLite
DATABASE_URL="file:./kpd.db"

# Neon (Vercel: Production + Build + Preview):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Без channel_binding=require — на Vercel ломает подключение.
# DIRECT_URL (опционально) — direct endpoint для db push при сборке:
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Схему в Neon применяйте вручную (не во время сборки Vercel):
# $env:DATABASE_URL="postgresql://...pooler...?sslmode=require"
# $env:DIRECT_URL="postgresql://...без-pooler...?sslmode=require"
# npm run db:migrate
# npm run db:seed
#
# Vercel build: только prisma generate + next build (db push отдельно).

NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
# NextAuth v5 (за reverse-proxy в проде: AUTH_TRUST_HOST=true)
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="false"
