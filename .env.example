# Локально — SQLite
DATABASE_URL="file:./kpd.db"

# Neon — только через переменную сессии (не кладите в .env для локалки):
# $env:DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# npm run db:migrate
# npm run db:seed          # после migrate; generate встроен в скрипт
#
# Если migrate упал (P3009 / failed migration):
# npm run db:migrate:recover

NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
